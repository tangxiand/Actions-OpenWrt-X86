# ================== 基础平台设置 ==================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# ================== 固件大小设置 ==================
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_EXT4_IMAGES=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ================== 全局语言支持 ==================
CONFIG_BUILD_NLS=y

# ================== 核心功能 ==================
# 完整 IPv6 支持
CONFIG_IPV6=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_odhcpd=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y

# 负载均衡
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_mwan3=y

# ZeroTier
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_zerotier=y

# iStore 应用商店
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-istorex=y
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-app-diskman=y

# socat 端口转发工具
CONFIG_PACKAGE_luci-app-socat=y
CONFIG_PACKAGE_socat=y

# DDNS
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_ddns-scripts_aliyun=y
CONFIG_PACKAGE_ddns-scripts_cloudflare=y
CONFIG_PACKAGE_ddns-scripts_dnspod=y

# 网络唤醒
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_wol=y

# 流量控制 (SQM)
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_sqm-scripts=y

# 终端流量监控 (wrtbwmon)
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_wrtbwmon=y

# 网络流量与状态监控 (Statistics)
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-interface=y
CONFIG_PACKAGE_collectd-mod-cpu=y
CONFIG_PACKAGE_collectd-mod-memory=y
CONFIG_PACKAGE_collectd-mod-rrdtool=y
CONFIG_PACKAGE_rrdtool1=y

# UPnP
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_miniupnpd=y

# ================== 界面与主题 ==================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-theme-argon-zh-cn=y
CONFIG_PACKAGE_luci-theme-argon-modern=y

# ================== 中文语言包（全插件汉化） ==================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_luci-i18n-wrtbwmon-zh-cn=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ================== 网卡驱动 (常见2.5G网卡) ==================
# Intel I225-V / I226-V 系列驱动
CONFIG_PACKAGE_kmod-igc=y
# Realtek RTL8125 / RTL8125B(S) 驱动
CONFIG_PACKAGE_kmod-r8169=y

# ================== 实用工具 ==================
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y

# iStore 依赖
CONFIG_PACKAGE_luci-compat=y
