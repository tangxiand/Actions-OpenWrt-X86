#
# 固件核心配置 (Target: x86/64)
#
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_generic=y
CONFIG_TARGET_x86_generic_DEVICE=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# 设置根文件系统分区大小为 1GB，确保有足够空间安装插件
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

#
# 内核模块 - 网卡驱动 (重点集成)
#
# Intel i225 / i226 2.5G 网卡驱动 (核心)
CONFIG_PACKAGE_kmod-igc=y
# Intel 其他常见网卡驱动
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-ixgbe=y
CONFIG_PACKAGE_kmod-i40e=y
# Realtek 常见网卡驱动 (2.5G/1G)
CONFIG_PACKAGE_kmod-r8125=y
CONFIG_PACKAGE_kmod-r8126=y
CONFIG_PACKAGE_kmod-r8168=y
CONFIG_PACKAGE_kmod-r8169=y
# Broadcom / Intel 千兆网卡
CONFIG_PACKAGE_kmod-tg3=y
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-e1000e=y

#
# 基础功能 - 中文、DDNS、网络唤醒、socat
#
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_luci-app-socat=y
CONFIG_PACKAGE_luci-i18n-socat-zh-cn=y

#
# 高级网络功能 - ZeroTier, 负载均衡, IPv6
#
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
CONFIG_PACKAGE_luci-app-mwan3=y
CONFIG_PACKAGE_luci-i18n-mwan3-zh-cn=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

#
# 应用与插件 - iStore, AdGuard Home, MosDNS
#
CONFIG_PACKAGE_luci-app-istore=y
CONFIG_PACKAGE_luci-i18n-istore-zh-cn=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
#CONFIG_PACKAGE_luci-app-mosdns=y
#CONFIG_PACKAGE_luci-i18n-mosdns-zh-cn=y

#
# 流量控制与监控 (爱快类功能核心)
#
# SQM QoS 流量控制
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y
CONFIG_PACKAGE_tc-mod-iptables=y
CONFIG_PACKAGE_tc=y

# nlbwmon 网络带宽监控 (按IP统计流量)
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y

# statistics (Netdata) 实时性能监控
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_collectd=y
CONFIG_PACKAGE_collectd-mod-netdata=y

#
# 界面与主题
#
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
# 禁用默认 Bootstrap 主题
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
